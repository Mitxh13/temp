# Copy this file to .env and adjust as needed.

# Base URL of the running llama.cpp server (llama-server)
LLAMA_SERVER_URL=http://127.0.0.1:8080

# How long to wait for the model to finish generating (seconds).
# CPU-only inference on a 3B model can be slow -- raise this if you see timeouts.
REQUEST_TIMEOUT_S=120

# Max tokens the model is allowed to generate for the narrative section.
MAX_TOKENS=700

# Sampling temperature. Kept low so the wording stays factual/consistent.
TEMPERATURE=0.3
